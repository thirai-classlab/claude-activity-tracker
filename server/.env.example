# Database (MariaDB)
# ローカル開発: DATABASE_URL="mysql://tracker:trackerpass@localhost:3306/claude_tracker"
# Docker Compose: DATABASE_URL="mysql://tracker:trackerpass@db:3306/claude_tracker"
DATABASE_URL="mysql://tracker:trackerpass@db:3306/claude_tracker"

# API Server
PORT=3001
NODE_ENV=development

# Docker host port mappings（既定: API=3010 / DB=3307、複数開発環境共存のため固定）
# 一般的な Next.js dev server (3000) や別 API (3001) と衝突しないよう、3010 を採用
# DB は localhost-only バインド（D-010）、汎用 MariaDB (3306) と衝突しないよう 3307
HOST_PORT=3010       # API server: 全 doctor/ install 動作前提
DB_HOST_PORT=3307    # MariaDB on 127.0.0.1:3307 (Prisma Studio / sync-pricing 用)

# API Key (Hook エンドポイントの認証)
# ⚠️ 本番環境では必ず安全なキーを生成して設定してください:
#   openssl rand -hex 32
# 未設定の場合: 認証がスキップされます（開発モード）
# 設定した場合: クライアント側 config.json の api_key と一致させる必要があります
API_KEY=

# Next.js Dashboard API Key (ブラウザからのAPI呼び出し用)
# API_KEY と同じ値を設定してください
# NEXT_PUBLIC_ prefix により Next.js がブラウザに公開します
NEXT_PUBLIC_API_KEY=

# Basic Auth (ダッシュボード UI の保護)
# 設定するとダッシュボード画面にBasic認証がかかります
# /api/* と /health はスキップされます
# ユーザー名は不要（空欄）、パスワードのみ
BASIC_AUTH_PASSWORD=

# Cost rates (per 1M tokens, USD)
# ⚠️ Phase 2 (docs/specs/002-model-pricing-registry.md) 実装後は、DB の model_pricing テーブルが一次ソースになります。
# 下記の環境変数は manual_override レコードとして保存され、DB/外部JSON より優先されます。
# 未設定時は LiteLLM JSON (https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json) から自動同期。
COST_OPUS_INPUT=15
COST_OPUS_OUTPUT=75
COST_SONNET_INPUT=3
COST_SONNET_OUTPUT=15
COST_HAIKU_INPUT=0.80
COST_HAIKU_OUTPUT=4

# Anthropic API Key
# 用途1: AI分析チャット機能
# 用途2: Phase 2 料金同期で /v1/models エンドポイントからモデル一覧取得（verification 用、料金本体は LiteLLM JSON 経由）
# 取得: https://console.anthropic.com/
# 未設定時: AI Chat は OAuth Token にフォールバック、料金同期は LiteLLM のモデル一覧のみで動作
ANTHROPIC_API_KEY=

# OAuth Token (AI Chat 用の代替、claude setup-token で生成、Claude Pro/Max推奨)
#CLAUDE_CODE_OAUTH_TOKEN=

# Pricing Sync (Phase 2)
# 料金データの同期間隔（秒）。未設定時は 3600 (1時間)
#PRICING_SYNC_INTERVAL_SEC=3600
# 料金同期を無効化する（CI / オフライン環境用）。'1' で disable
#PRICING_SYNC_DISABLED=0
# LiteLLM JSON の URL（固定値、変更不要。デバッグ時のみ上書き）
#LITELLM_PRICING_URL=https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json

# Next.js App Directory（dist 構造変更後のパス解決用、通常未設定で OK）
# projectRoot 解決ロジックが自動判定するため、Docker / PM2 等の非標準配置でのみ設定
#NEXT_APP_DIR=/app

# Metrics Correction Cutoff
# 2026-04-25 以前のセッションはパーサバグによりトークン・コスト・ターン数が
# 1.7〜62 倍に膨張しています。バックフィルを行わないため、ダッシュボードに
# 「計測不能期間」バナーを表示するための cutoff 日付 (ISO 8601: YYYY-MM-DD)。
# 未設定時: 既定値 2026-04-25 が使用されます。
# NEXT_PUBLIC_METRICS_FIXED_SINCE を設定すると Next.js クライアント側でも参照可能です
# (未設定時は METRICS_FIXED_SINCE にフォールバック、それも未設定なら 2026-04-25)。
# 詳細: docs/specs/001-transcript-dedup.md / docs/announcements/2026-04-data-correction.md
METRICS_FIXED_SINCE=2026-04-25
NEXT_PUBLIC_METRICS_FIXED_SINCE=2026-04-25

# GitHub MCP Integration (GitHub リポジトリ分析機能)
# Fine-grained PAT を作成: https://github.com/settings/personal-access-tokens/new
# 必要な権限: Contents (Read-only)
# 設定するとAI分析チャットでリポジトリのファイル内容・コミット・PR等を参照可能
# 未設定の場合: GitHub連携機能はスキップされます
GITHUB_PAT=

# Application Timezone (集計タイムゾーン)
# ダッシュボードの日次集計を JST 等で行うためのオフセット（'+09:00' 形式）
# 未設定時のデフォルト: '+09:00'（JST）
# 海外チームは '+00:00'（UTC）等で上書き可能
# 詳細: docs/specs/009-timezone-aggregation.md
#APP_TIMEZONE=+09:00

# Docs Directory (static /docs route)
# ダッシュボードから docs/ 配下の Markdown を配信するディレクトリ。
# 未設定時のデフォルト: process.cwd()/../docs （ローカル開発では server/ から見た ../docs = リポジトリ docs/）
# Docker: compose が /app/docs に bind mount し、DOCS_DIR=/app/docs を設定します。
# URL 例: /docs/announcements/2026-04-data-correction.md
# 詳細: docs/decisions/resolved.md (D-007)
#DOCS_DIR=/app/docs

# -------------------------------------------------------
# Docker Usage
# -------------------------------------------------------
# 1. Copy this file to .env and edit as needed:
#      cp .env.example .env
#
# 2. Generate and set a secure API key:
#      echo "API_KEY=$(openssl rand -hex 32)" >> .env
#
# 3. Build and start with Docker Compose (MariaDB + API):
#      docker compose up -d --build
#
# 4. Verify:
#      curl http://localhost:3001/health
#
# ⚠️ .env を変更した場合:
#    docker compose restart では反映されません。
#    docker compose up -d --force-recreate で再作成してください。
# -------------------------------------------------------
